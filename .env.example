# NeuralHub 配置模板 —— 复制为 .env 后按需填写
# 每个键的详细说明见 docs/configuration.md
# ⚠️ 改动 .env 需 `docker compose up -d app` 重建容器才生效（restart 不读新 env）

# === 最小可跑集（必填） ===
DATABASE_URL=
# DATABASE_URL=postgresql+asyncpg://agent:password@localhost:5432/agent_studio
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0
# 生产必改：openssl rand -hex 32（同时是前端登录口令与 Cookie 扩展口令）
AUTH_SECRET=change-me-in-production

# === LLM Provider（至少配一个；OpenAI 兼容中转也可在 Web 设置页配） ===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=kimi-k2.6
ENABLE_TOOL_SEARCH=true

# LLM 容错链（可选）：主 provider 挂了按序降级
# LLM_FALLBACK_PROVIDER_IDS=
# LLM_FALLBACK_CIRCUIT_THRESHOLD=3
# LLM_FALLBACK_CIRCUIT_SECONDS=300

# === Server ===
API_HOST=127.0.0.1
API_PORT=8000

# === X / Twitter（搜索内核，twikit 非官方接口，仅内部使用） ===
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
# 国内必填代理，如 http://127.0.0.1:7890
TWITTER_PROXY_URL=
# 首次账密登录后 cookie 持久化于此，之后免登录；Docker 部署放项目根目录
TWITTER_COOKIES_FILE=twitter_cookies.json

# === X 舆情雷达 REST API（默认关闭；用法见 docs/x-api.md） ===
X_API_ENABLED=false
X_MONITOR_ENABLED=false
# X_SEARCH_CACHE_TTL_SECONDS=300
# X_CALL_MIN_INTERVAL_SECONDS=5
# X_DAILY_CALL_BUDGET=200
# X_RANK_WEIGHT_LIKES=1.0
# X_RANK_WEIGHT_RETWEETS=2.0
# X_RANK_WEIGHT_VIEWS=0.01
# X_MONITOR_MIN_INTERVAL_MINUTES=15
# X_MONITOR_MAX_COUNT=20

# === 飞书：单向通知（自定义机器人 webhook） ===
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# === 飞书：双向对话（企业自建应用；权限 im:message:receive_v1 / im:message:send_v1 / im:chat:readonly） ===
# 事件回调地址：https://你的域名/api/feishu/event
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# === AI 早报接收人 ===
MORNING_REPORT_USER_IDS=default
MORNING_REPORT_CHAT_ID=

# === 知识库 RAG（pgvector + 智谱 embedding） ===
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=2048
KNOWLEDGE_UPLOAD_DIR=data/knowledge_uploads
# KNOWLEDGE_SCORE_THRESHOLD=0.35

# === 搜索与外部服务（按需） ===
ZHIPU_WEB_SEARCH_API_KEY=
YOUTUBE_API_KEY=
# 国内需代理，如 http://127.0.0.1:7890
YOUTUBE_PROXY_URL=
EXA_API_KEY=
EXA_PROXY_URL=
NOTION_API_KEY=

# === 本机代理内核 mihomo（X/YouTube 出海流量依赖它；节点不健康早报会空） ===
MIHOMO_API_URL=http://127.0.0.1:9090
MIHOMO_SECRET=
# 以下仅本机托管 mihomo 时需要
# MIHOMO_PATH=
# MIHOMO_CONFIG_PATH=
# MIHOMO_WORK_DIR=
# MIHOMO_SUB_PATH=

# === 运行与调优（有合理默认） ===
# 生产建议 false，让 alembic 迁移成为 schema 唯一权威
# AUTO_CREATE_TABLES=true
SUB_WORKER_CONCURRENCY=2
# MAX_CONTEXT_TOKENS=128000
# COMPACT_THRESHOLD_L2=0.5
# COMPACT_THRESHOLD_L3=0.7
# 浏览器端可选的服务器工作区根目录（逗号分隔）
# WORKSPACE_ROOTS=/app
# GUNICORN_WORKERS=1

# === 日志与观测（默认 file；上 Loki 栈时切换） ===
# LOG_LEVEL=info
# LOG_SEARCH_BACKEND=file
# LOKI_BASE_URL=http://127.0.0.1:3100
# LOKI_APP_LABEL=agent-studio
# METRICS_TTL_DAYS=400
